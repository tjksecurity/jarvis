# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
# JARVIS_MODEL=claude-opus-4-7
# JARVIS_EFFORT=xhigh           # low | medium | high | xhigh | max
# JARVIS_VOICE=Ava              # any macOS `say` voice (try: say -v ?)
# JARVIS_SPEAK=1                # 1 = speak responses by default (macOS only)
# JARVIS_SPEAK_RATE=210         # words per minute for `say`
# JARVIS_USER_NAME=Commander    # how EVA addresses you
# JARVIS_HOME=~/.jarvis         # state directory (memory, logs)
